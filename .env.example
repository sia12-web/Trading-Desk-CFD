# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OANDA Demo Account (for testing)
OANDA_DEMO_API_KEY=your-demo-api-key
OANDA_DEMO_ACCOUNT_ID=your-demo-account-id
OANDA_DEMO_API_URL=https://api-fxpractice.oanda.com

# OANDA Live Account (production trading)
OANDA_LIVE_API_KEY=your-live-api-key
OANDA_LIVE_ACCOUNT_ID=your-live-account-id
OANDA_LIVE_API_URL=https://api-fxtrade.oanda.com

# Web Push Notifications (VAPID keys)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:your-email@example.com

# Cron Job Security
CRON_SECRET=generate-a-random-secret-string

# App URL
NEXT_PUBLIC_APP_URL=https://your-app.railway.app

# AI Model API Keys (Tri-Model Pipeline)
# Claude (Decision Architect) - https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Gemini (Pattern Archaeologist) - https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy-your-key-here

# DeepSeek (Quantitative Engine) - https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-key-here

# Telegram Bot (for 24/7 mentor) - Get this from @BotFather in Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-numeric-chat-id-here

# Coinbase Advanced Trade API - https://cloud.coinbase.com/access/api
COINBASE_API_KEY_NAME=your-api-key-name
COINBASE_API_KEY_PRIVATE=your-api-key-private-hex-string
