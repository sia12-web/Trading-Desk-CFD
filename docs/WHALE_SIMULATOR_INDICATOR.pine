//@version=5
indicator("Whale Simulator - AI Trio Signals", overlay=true, max_labels_count=500)

// ═══════════════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════════════

showDonchian = input.bool(true, "Show Donchian Channel", group="Indicators")
donchianPeriod = input.int(20, "Donchian Period", minval=5, maxval=100, group="Indicators")

showVolumePOC = input.bool(true, "Show Volume POC", group="Indicators")
pocPeriod = input.int(30, "POC Lookback", minval=10, maxval=200, group="Indicators")

showCVD = input.bool(true, "Show CVD Divergence", group="Indicators")
cvdPeriod = input.int(50, "CVD Period", minval=20, maxval=200, group="Indicators")

showWhaleZones = input.bool(true, "Show Whale Zones", group="Whale Signals")
showAccumulation = input.bool(true, "Accumulation Markers", group="Whale Signals")
showManipulation = input.bool(true, "Manipulation Markers", group="Whale Signals")
showDistribution = input.bool(true, "Distribution Markers", group="Whale Signals")

// ═══════════════════════════════════════════════════════════════════════════
// DONCHIAN CHANNEL (20-period rolling high/low)
// ═══════════════════════════════════════════════════════════════════════════

donchianHigh = ta.highest(high, donchianPeriod)
donchianLow = ta.lowest(low, donchianPeriod)
donchianMid = (donchianHigh + donchianLow) / 2

plot(showDonchian ? donchianHigh : na, "Donchian High", color=color.new(color.blue, 70), linewidth=1, style=plot.style_linebr)
plot(showDonchian ? donchianLow : na, "Donchian Low", color=color.new(color.blue, 70), linewidth=1, style=plot.style_linebr)

// ═══════════════════════════════════════════════════════════════════════════
// VOLUME POC (Simplified — using VWAP as proxy)
// ═══════════════════════════════════════════════════════════════════════════

// Simple Volume POC approximation using anchored VWAP
vwapValue = ta.vwap(close)
plot(showVolumePOC ? vwapValue : na, "Volume POC (VWAP)", color=color.new(color.orange, 50), linewidth=1, style=plot.style_cross)

// ═══════════════════════════════════════════════════════════════════════════
// CVD (Cumulative Volume Delta) — Simplified
// ═══════════════════════════════════════════════════════════════════════════

// Tick volume delta approximation
delta = close > close[1] ? volume : close < close[1] ? -volume : 0
cvd = ta.cum(delta)
cvdMA = ta.sma(cvd, cvdPeriod)

// Detect CVD divergence
pricePeak = ta.pivothigh(close, 5, 5)
priceTrough = ta.pivotlow(close, 5, 5)

cvdPeak = ta.pivothigh(cvd, 5, 5)
cvdTrough = ta.pivotlow(cvd, 5, 5)

// Bearish divergence: price making higher high, CVD making lower high
bearishDiv = not na(pricePeak) and not na(cvdPeak) and close > close[10] and cvd < cvd[10]

// Bullish divergence: price making lower low, CVD making higher low
bullishDiv = not na(priceTrough) and not na(cvdTrough) and close < close[10] and cvd > cvd[10]

// ═══════════════════════════════════════════════════════════════════════════
// WHALE SIGNAL DETECTION
// ═══════════════════════════════════════════════════════════════════════════

// Accumulation Zone: Price near Donchian Low + CVD rising
inAccumulationZone = close <= donchianLow * 1.005 and cvd > cvdMA
accumulate = inAccumulationZone and ta.crossover(cvd, cvdMA)

// Manipulation Zone: Donchian breakout + high volume + CVD divergence
volumeSpike = volume > ta.sma(volume, 20) * 2
donchianBreakout = close > donchianHigh or close < donchianLow
manipulate = donchianBreakout and volumeSpike and (bearishDiv or bullishDiv)

// Distribution Zone: Price near Donchian High + CVD falling
inDistributionZone = close >= donchianHigh * 0.995 and cvd < cvdMA
distribute = inDistributionZone and ta.crossunder(cvd, cvdMA)

// ═══════════════════════════════════════════════════════════════════════════
// WHALE ZONES (Background Coloring)
// ═══════════════════════════════════════════════════════════════════════════

bgcolor(showWhaleZones and inAccumulationZone ? color.new(color.blue, 95) : na, title="Accumulation Zone")
bgcolor(showWhaleZones and inDistributionZone ? color.new(color.red, 95) : na, title="Distribution Zone")

// ═══════════════════════════════════════════════════════════════════════════
// PLOT SIGNALS
// ═══════════════════════════════════════════════════════════════════════════

// Accumulation (Blue circle below bar)
plotshape(showAccumulation and accumulate, "Accumulation", shape.circle, location.belowbar, color=color.new(color.blue, 0), size=size.small, text="BUY")

// Manipulation (Orange triangle above/below bar)
plotshape(showManipulation and manipulate and close > donchianHigh, "Manipulation Up", shape.triangledown, location.abovebar, color=color.new(color.orange, 0), size=size.small, text="HUNT")
plotshape(showManipulation and manipulate and close < donchianLow, "Manipulation Down", shape.triangleup, location.belowbar, color=color.new(color.orange, 0), size=size.small, text="HUNT")

// Distribution (Red circle above bar)
plotshape(showDistribution and distribute, "Distribution", shape.circle, location.abovebar, color=color.new(color.red, 0), size=size.small, text="SELL")

// ═══════════════════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════════════════

alertcondition(accumulate, "Whale Accumulation", "🐋 Whale accumulating at {{ticker}} @ {{close}}")
alertcondition(manipulate, "Whale Manipulation", "⚠️ Stop hunt detected at {{ticker}} @ {{close}}")
alertcondition(distribute, "Whale Distribution", "🚨 Whale distributing at {{ticker}} @ {{close}}")

// ═══════════════════════════════════════════════════════════════════════════
// INFO TABLE
// ═══════════════════════════════════════════════════════════════════════════

if barstate.islast
    var table infoTable = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black, 20), border_width=1, border_color=color.new(color.gray, 50))

    table.cell(infoTable, 0, 0, "Whale Simulator", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 70))
    table.cell(infoTable, 1, 0, "Status", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 70))

    // Current phase
    currentPhase = inAccumulationZone ? "Accumulation" : inDistributionZone ? "Distribution" : "Neutral"
    phaseColor = inAccumulationZone ? color.blue : inDistributionZone ? color.red : color.gray

    table.cell(infoTable, 0, 1, "Phase", text_color=color.gray)
    table.cell(infoTable, 1, 1, currentPhase, text_color=phaseColor)

    // CVD Trend
    cvdTrend = cvd > cvdMA ? "Bullish" : "Bearish"
    cvdColor = cvd > cvdMA ? color.green : color.red

    table.cell(infoTable, 0, 2, "CVD", text_color=color.gray)
    table.cell(infoTable, 1, 2, cvdTrend, text_color=cvdColor)

    // Donchian Position
    donchianPos = close > donchianMid ? "Above Mid" : "Below Mid"
    donchianColor = close > donchianMid ? color.green : color.red

    table.cell(infoTable, 0, 3, "Donchian", text_color=color.gray)
    table.cell(infoTable, 1, 3, donchianPos, text_color=donchianColor)

    // Volume
    volumeStatus = volume > ta.sma(volume, 20) * 2 ? "Spike" : "Normal"
    volumeColor = volume > ta.sma(volume, 20) * 2 ? color.orange : color.gray

    table.cell(infoTable, 0, 4, "Volume", text_color=color.gray)
    table.cell(infoTable, 1, 4, volumeStatus, text_color=volumeColor)

    // Signal
    signal = accumulate ? "BUY" : manipulate ? "HUNT" : distribute ? "SELL" : "HOLD"
    signalColor = accumulate ? color.blue : manipulate ? color.orange : distribute ? color.red : color.gray

    table.cell(infoTable, 0, 5, "Signal", text_color=color.gray)
    table.cell(infoTable, 1, 5, signal, text_color=signalColor, text_size=size.large)
